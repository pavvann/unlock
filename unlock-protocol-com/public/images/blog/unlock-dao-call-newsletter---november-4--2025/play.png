tion\",null,{\"className\":\"scroll-snap-section bg-background\",\"children\":[\"$\",\"$L43\",null,{}]}],[\"$\",\"section\",null,{\"className\":\"scroll-snap-section bg-background\",\"children\":[\"$\",\"$L44\",null,{\"children\":[\"$\",\"$2b\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"w-full\",\"children\":[\"$\",\"$L45\",null,{\"publications\":[{\"id\":\"RiSgH90rlXboE2f3FnSK\",\"name\":\"AVC\",\"url\":\"@avc\",\"description\":\"I am a VC.\"},{\"id\":\"5DdgMh0tMrYzjWWoMVNT\",\"name\":\"Debbie Soon\",\"url\":\"@debbie\",\"description\":\"A collection of personal essays, and an extension of my onchain photography collection, Places Dobbie Seen.\"},{\"id\":\"D9YJuccLaKARzB7O0MJf\",\"name\":\"Coop Records\",\"url\":\"@cooprecs\",\"description\":\"The best way to stay up on new music, products, events and more from Coop Records.\"},{\"id\":\"dqKcJeryGZZjRlnOhXxl\",\"name\":\"Zerion\",\"url\":\"@onchain.zerion\",\"description\":\"Your crypto wallet for everything onchain.\"},{\"id\":\"cN0u09vE5TyjBMqA9I7F\",\"name\":\"Decentralized Pictures\",\"url\":\"@decentralizedpictures\",\"description\":\"A newsletter for indie filmmakers and emerging artists. Creativity is for everyone.\"},{\"id\":\"pHAshSx8bisCrfs1oLpg\",\"name\":\"Assetux\",\"url\":\"@assetux\",\"description\":\"Mine Bitcoin with microtasks on Telegram.\\nAccess $BTC on TON Blockchain.\\nSpend across millions of merchants worldwide.\"},{\"id\":\"malkJGtn0mhXnWaNejzt\",\"name\":\"Babylon\",\"url\":\"@playbabylon\",\"description\":\"Babylon is a place where humans and AI agents make predictions, test strategies, and learn how to work together inside one shared world. It runs nonstop, new events appear all the time, and both people and agents react, make calls, and see outcomes settle quickly. It’s basically a training ground to understand how intelligent agents behave, how they coordinate, and how onchain systems might work when humans and AI operate side by side.\"},{\"id\":\"1HSqvpNyUtEWO2fzI5PB\",\"name\":\"Taiko Labs\",\"url\":\"@taiko-labs\",\"description\":\"An Ethereum Based Rollup.\"},{\"id\":\"uQL4WRZHmhEYDGbLsew3\",\"name\":\"FOLIO\",\"url\":\"@folio\",\"description\":\"Sharing updates about FOLIO, an Opinion Polling Platform for Crowd-Forecasting, Gamified Market Research, and Daily Rewards.\"},{\"id\":\"RL7LKMOiT9Yg2AQmj8fq\",\"name\":\"News from RBC GranFondo\",\"url\":\"@rbcgranfondo\",\"description\":\"North America's biggest Gran Fondo, open to all.\"},{\"id\":\"0etmlkv2oPdpZS0tQvAA\",\"name\":\"Reef Chain News\",\"url\":\"@reefchain\",\"description\":\"Reef Chain is laying the foundations for everyone to own their financial future.\"},{\"id\":\"rgVL5FvBoC2zGNI9j3e3\",\"name\":\"CoinMath\",\"url\":\"@coinmath\",\"description\":\"CoinMath revolutionizes crypto asset management with user-friendly tools for mining, staking, and earning, empowering users to maximize their digital assets.\"},{\"id\":\"zCRl2qIrZoJRb6V3meBs\",\"name\":\"DHK dao\",\"url\":\"@dhk\",\"description\":\"Web3 公民教育 | Civic education for web3.\"},{\"id\":\"wGiwDb7T08K7dJlfFffS\",\"name\":\"IndyPen CryptoMedia\",\"url\":\"@indypen\",\"description\":\"IndyPen CryptoMedia publishes a wide range of web3-related content written by independent authors.\"},{\"id\":\"4st52QCsAEiTJlAUYqAD\",\"name\":\"Horizen Blog\",\"url\":\"@horizenofficial-2\",\"description\":\"Powering privacy-first and regulatory-ready infrastructure for the new digital economy.\"},{\"id\":\"dZrlXrAD2EP7vL1JVvxk\",\"name\":\"What Wilson Heard\",\"url\":\"@hanverstraete.eth\",\"description\":\"A blog by recidivist founder Han Verstraete with ideas and thoughts how to author your life in Web3 and beyond.\"},{\"id\":\"ZWHS1hLpSpGhcs0pyRvM\",\"name\":\"Devcon newsletter\",\"url\":\"@efevents\",\"description\":\"Sign up to receive updates about Devcon, the flagship event of the Ethereum Foundation. Devcon 8 will take place in Q4 2026 in Mumbai, India.\"},{\"id\":\"SV3Nigh1ROky9noQEqL2\",\"name\":\"Mode\",\"url\":\"@modenetwork\",\"description\":\"Mode L2 scales DeFi to billions of users through onchain agents and AI-powered financial applications. Mode is building the AIFi economy.\"},{\"id\":\"qYLtGesdzUlseK0GjJNC\",\"name\":\"LikeCoin\",\"url\":\"@likecoin\",\"description\":\"LikeCoin is the DeBook protocol powering 3ook.com, a decentralized book store.\"},{\"id\":\"cmjKmyFr4kNegz0J3NX8\",\"name\":\"talent\",\"url\":\"@talent\",\"description\":\"Giving builders the recognition they deserve.\"},{\"id\":\"IKDVsi66g4EvJgIBcQiH\",\"name\":\"AyaHQ\",\"url\":\"@ayahq\",\"description\":\"Stay connected and up to date with the latest developments in the AyaHQ ecosystem.\"},{\"id\":\"hL46JQWFi70m23hOjl96\",\"name\":\"Bakaka\",\"url\":\"@bakaka\",\"description\":\"This publication explores the intersection of crypto, artificial intelligence, the open web, and agentic networks. I write from the perspective of someone focused on infrastructure, real-world adoption, and systems that scale beyond hype. Topics range from blockchain payment rails and stablecoins to AI coordination, autonomous agents, and the networks that will power the next phase of the internet, especially in emerging markets. The goal is simple: thoughtful analysis, grounded opinions, and practical insight into where technology is actually heading.\"},{\"id\":\"4HOP5zMeZOx2TSE1rJ8X\",\"name\":\"Onchain @ Zerion\",\"url\":\"@zerion\",\"description\":\"Get product updates on Zerion Wallet \u0026 Zerion API.\"},{\"id\":\"SkL5sbBOiS6TwpnTIY3P\",\"name\":\"Daylight\",\"url\":\"@daylightenergy\",\"description\":\"The decentralized energy company.\"},{\"id\":\"wn7Lni9gZPRDstncHlgX\",\"name\":\"ANTIBLOG\",\"url\":\"@lght.eth\",\"description\":\"This is not a blog.\"},{\"id\":\"WTlBnRUBpkCSWsHSykOu\",\"name\":\"Safecast\",\"url\":\"@safecast\",\"description\":\"Updates from Safecast on how open environmental data empowers citizens and communities worldwide.\"},{\"id\":\"rrhd9WXLWLjVjmy5g6jY\",\"name\":\"Poster.fun\",\"url\":\"@poster\",\"description\":\"Curated news from best of Onchain + Ai + cc0 based remix dApps.\"},{\"id\":\"mRzqbIuYwOlMAG2nYLvY\",\"name\":\"Proof of PortCo\",\"url\":\"@mhventures\",\"description\":\"Proof of Portco is MH Ventures’ monthly pulse check on the builders we back. Each issue serves as onchain style “proof” of real progress: rapid-fire founder Q\u0026A, milestone highlights, key asks, and the latest episodes from our Dealflow Podcast. Proof of Portco keeps investors, founders, and friends in the loop, showing exactly how our portfolio is compounding momentum, one verifiable update at a time.\"},{\"id\":\"1pqFXMYxoSWSsfxCK7E4\",\"name\":\"Chainbase Network - Blog\",\"url\":\"@chainbase\",\"description\":\"The Hyperdata Network built to transform fragmented blockchain signals into structured, verifiable, and AI-ready data, enabling permissionless coordination between agents, apps, and humans in a unified data economy.\"}],\"logoMap\":{\"RiSgH90rlXboE2f3FnSK\":{\"small\":\"$L46\",\"large\":\"$L47\"},\"5DdgMh0tMrYzjWWoMVNT\":{\"small\":\"$L48\",\"large\":\"$L49\"},\"D9YJuccLaKARzB7O0MJf\":{\"small\":\"$L4a\",\"large\":\"$L4b\"},\"dqKcJeryGZZjRlnOhXxl\":{\"small\":\"$L4c\",\"large\":\"$L4d\"},\"cN0u09vE5TyjBMqA9I7F\":{\"small\":\"$L4e\",\"large\":\"$L4f\"},\"pHAshSx8bisCrfs1oLpg\":{\"small\":\"$L50\",\"large\":\"$L51\"},\"malkJGtn0mhXnWaNejzt\":{\"small\":\"$L52\",\"large\":\"$L53\"},\"1HSqvpNyUtEWO2fzI5PB\":{\"small\":\"$L54\",\"large\":\"$L55\"},\"uQL4WRZHmhEYDGbLsew3\":{\"small\":\"$L56\",\"large\":\"$L57\"},\"RL7LKMOiT9Yg2AQmj8fq\":{\"small\":\"$L58\",\"large\":\"$L59\"},\"0etmlkv2oPdpZS0tQvAA\":{\"small\":\"$L5a\",\"large\":\"$L5b\"},\"rgVL5FvBoC2zGNI9j3e3\":{\"small\":\"$L5c\",\"large\":\"$L5d\"},\"zCRl2qIrZoJRb6V3meBs\":{\"small\":\"$L5e\",\"large\":\"$L5f\"},\"wGiwDb7T08K7dJlfFffS\":{\"small\":\"$L60\",\"large\":\"$L61\"},\"4st52QCsAEiTJlAUYqAD\":{\"small\":\"$L62\",\"large\":\"$L63\"},\"dZrlXrAD2EP7vL1JVvxk\":{\"small\":\"$L64\",\"large\":\"$L65\"},\"ZWHS1hLp